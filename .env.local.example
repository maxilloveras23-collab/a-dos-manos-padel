# Copiar a .env.local y completar cuando se creen las cuentas

# Supabase (https://supabase.com/dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago (https://www.mercadopago.com.ar/developers/panel)
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# URL pública del sitio (para webhooks de MP y emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Panel admin: emails con acceso, separados por coma
ADMIN_EMAILS=
